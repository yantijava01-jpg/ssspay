# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ssspay?retryWrites=true&w=majority

# JWT
JWT_SECRET=ssspay_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Admin Seed (initial admin account)
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=Admin@1234

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173
